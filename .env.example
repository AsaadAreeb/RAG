# ── API Keys ──────────────────────────────────
XAI_API_KEY=
GEMINI_API_KEY=

# ── Models ────────────────────────────────────
GROK_MODEL=grok-3
GEMINI_MODEL=gemini-2.5-flash

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Chroma ────────────────────────────────────
CHROMA_PATH=./storage/chroma
CHROMA_COLLECTION=rag_documents

# ── SQL Database ──────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/app.db

# ── Embedding Model ───────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking ──────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ── Retrieval ─────────────────────────────────
TOP_K=5
NEXT_K=8
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_RPM=10
REQUESTS_PER_USER_PER_MIN=10

# ── Security ──────────────────────────────────
SECRET_KEY=change_me_to_a_strong_secret